# Copy this file to .env, or run:
#   ./scripts/setup-docker-server.sh
#
# The generated .env contains the server secret. Keep it private.

PORTHOLE_PUBLIC_HOST=203.0.113.10
PORTHOLE_SECRET=replace-with-a-random-secret

PORTHOLE_CONTROL_PORT=7835
PORTHOLE_MIN_PORT=10000
PORTHOLE_MAX_PORT=20000
PORTHOLE_LOG_LEVEL=info
PORTHOLE_LOG_MODE=console

# Override to use a fork, local registry, or pinned release image.
# PORTHOLE_IMAGE=ghcr.io/sudo-ds/porthole:latest
